<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#F5F5F5"
    android:paddingStart="24dp"
    android:paddingEnd="24dp"
    android:paddingTop="40dp"
    android:paddingBottom="24dp">

    <!-- Título -->
    <TextView
        android:id="@+id/tvDashboardTitulo"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:text="Tela Principal"
        android:textColor="#212121"
        android:textSize="26sp"
        android:textStyle="bold"
        android:gravity="center"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent" />

    <!-- Orçamento -->
    <TextView
        android:id="@+id/tvOrcamento"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:text="Orçamento: R$500   |   Gasto: R$320"
        android:textColor="#424242"
        android:textSize="16sp"
        android:gravity="center"
        android:padding="12dp"
        android:background="@drawable/bg_edittext"
        app:layout_constraintTop_toBottomOf="@id/tvDashboardTitulo"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        android:layout_marginTop="24dp" />

    <!-- RecyclerView para lista de veículos -->
    <androidx.recyclerview.widget.RecyclerView
        android:id="@+id/rvVeiculos"
        android:layout_width="0dp"
        android:layout_height="0dp"
        android:clipToPadding="false"
        android:paddingTop="16dp"
        android:paddingBottom="16dp"
        app:layout_constraintTop_toBottomOf="@id/tvOrcamento"
        app:layout_constraintBottom_toTopOf="@id/btnRegistrarManutencao"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        android:scrollbars="vertical" />

    <!-- Botão Registrar Manutenção -->
    <Button
        android:id="@+id/btnRegistrarManutencao"
        android:layout_width="0dp"
        android:layout_height="55dp"
        android:text="Registrar Manutenção"
        android:textSize="18sp"
        android:backgroundTint="#FF9800"
        android:textColor="#FFFFFF"
        app:layout_constraintBottom_toTopOf="@id/btnHistorico"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        android:layout_marginBottom="16dp" />

    <!-- Botão Histórico de Manutenções -->
    <Button
        android:id="@+id/btnHistorico"
        android:layout_width="0dp"
        android:layout_height="55dp"
        android:text="Histórico de Manutenções"
        android:textSize="18sp"
        android:backgroundTint="#FF9800"
        android:textColor="#FFFFFF"
        app:layout_constraintBottom_toTopOf="@id/btnGraficos"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        android:layout_marginBottom="16dp" />

    <!-- NOVO BOTÃO: Gráficos e Relatórios -->
    <Button
        android:id="@+id/btnGraficos"
        android:layout_width="0dp"
        android:layout_height="55dp"
        android:text="Gráficos e Relatórios"
        android:textSize="18sp"
        android:backgroundTint="#4CAF50"
        android:textColor="#FFFFFF"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent" />

</androidx.constraintlayout.widget.ConstraintLayout>
